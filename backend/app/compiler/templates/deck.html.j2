<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
<title>{{ meta.title }}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5/dist/reveal.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5/dist/theme/{{ meta.theme.value }}.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16/dist/katex.min.css">
<style>
  .sl-layout-title { display: flex; flex-direction: column; gap: 1rem; align-items: center; }
  .sl-layout-tc { display: flex; flex-direction: column; gap: 1.5rem; }
  .sl-layout-tc .sl-body { display: flex; flex-direction: column; gap: 1rem; }
  .sl-layout-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start; }
  .sl-layout-2col h2 { grid-column: 1 / -1; margin-bottom: 0.5rem; }
  .sl-layout-2col .sl-col { display: flex; flex-direction: column; gap: 1rem; }
  .sl-layout-bleed { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
  .sl-bullets { text-align: left; }
  .sl-bullets li { margin: 0.3em 0; }
  .sl-chart { width: 90%; height: 55vh; margin: 0 auto; }
  .sl-image { display: flex; flex-direction: column; align-items: center; }
  .sl-image img { max-width: 100%; max-height: 60vh; display: block; }
  .sl-image img[src=""], .sl-image img:not([src]) { display: none; }
  .sl-code { text-align: left; font-size: 0.55em; line-height: 1.3; }
  .sl-lead { font-size: 1.4em; opacity: 0.95; }
  .sl-caption { font-size: 0.7em; opacity: 0.7; }
  .sl-quote { font-size: 1.2em; font-style: italic; }
  .sl-subtitle { font-size: 1.2em; opacity: 0.8; }
  .sl-math { margin: 1rem 0; max-width: 100%; overflow: hidden; }
  .sl-math .katex-display { overflow-x: hidden; }
</style>
</head>
<body>
<!-- End-of-deck banner: fades in on the last slide -->
<div id="sl-end-banner" style="
  position:fixed; bottom:2.5rem; left:50%; transform:translateX(-50%);
  background:rgba(255,255,255,0.08); backdrop-filter:blur(8px);
  border:1px solid rgba(255,255,255,0.15); border-radius:9999px;
  padding:0.5rem 1.4rem; display:flex; align-items:center; gap:0.75rem;
  font-size:0.8rem; color:rgba(255,255,255,0.7); z-index:100;
  opacity:0; pointer-events:none;
  transition: opacity 0.4s ease;
">
  <span>End of deck</span>
  <span style="width:1px;height:1rem;background:rgba(255,255,255,0.2)"></span>
  <button onclick="Reveal.slide(0)" style="
    background:none; border:none; cursor:pointer;
    color:rgba(255,255,255,0.7); font-size:0.8rem; padding:0;
  ">↩ Restart</button>
</div>

<!-- Slide counter: positioned between ← and → by JS after Reveal init -->
<div id="sl-counter" style="
  position:fixed; z-index:35; pointer-events:none;
  font-size:11px; font-family:monospace;
  color:rgba(255,255,255,0.45); line-height:1;
  white-space:nowrap;
"></div>

<div class="reveal">
  <div class="slides">
    {% for slide_html in slides_html %}{{ slide_html | safe }}{% endfor %}
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/reveal.js@5/dist/reveal.js"></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16/dist/katex.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16/dist/contrib/auto-render.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script src="https://cdn.jsdelivr.net/npm/reveal.js@5/plugin/notes/notes.js"></script>
<script>
  function renderMath() {
    if (window.renderMathInElement) {
      renderMathInElement(document.body, {
        delimiters: [
          {left: '$$', right: '$$', display: true},
          {left: '\\(', right: '\\)', display: false},
        ],
        throwOnError: false,
      });
    }
    scaleMathBlocks();
  }

  /**
   * Scale down any math block whose rendered KaTeX content is wider than
   * its container. Uses CSS transform so the formula stays readable rather
   * than being clipped or scrolled.
   */
  function scaleMathBlocks() {
    document.querySelectorAll('.sl-math').forEach(function(el) {
      // KaTeX display mode wraps in .katex-display; inline mode just has .katex
      var displayEl = el.querySelector('.katex-display');
      var target = displayEl || el.querySelector('.katex');
      if (!target) return;

      // Reset previous scaling before measuring
      target.style.transform = '';
      target.style.transformOrigin = '';

      var containerW = el.clientWidth;
      var contentW = target.scrollWidth;
      if (contentW > containerW && containerW > 0) {
        var scale = (containerW / contentW) * 0.97; // 3% padding so it doesn't touch the edge
        target.style.transform = 'scale(' + scale + ')';
        target.style.transformOrigin = 'center top';
      }
    });
  }

  /**
   * Scale down any slide whose content is taller or wider than the Reveal
   * canvas. Targets the outermost sl-layout-* div inside each section so
   * the slide title and body shrink together as a unit.
   *
   * Called after Reveal finishes layout so section.clientHeight is reliable.
   */
  function scaleSlideContent() {
    document.querySelectorAll('.reveal .slides > section').forEach(function(section) {
      var content = section.querySelector('[class*="sl-layout-"]');
      if (!content) return;

      // Reset before measuring so we read natural (unscaled) dimensions
      content.style.transform = '';
      content.style.transformOrigin = '';

      var availH = section.clientHeight;
      var availW = section.clientWidth;
      if (availH === 0 || availW === 0) return; // not yet laid out

      var contentH = content.scrollHeight;
      var contentW = content.scrollWidth;

      var scaleH = contentH > availH ? availH / contentH : 1;
      var scaleW = contentW > availW ? availW / contentW : 1;
      var scale = Math.min(scaleH, scaleW) * 0.96; // 4% breathing room

      if (scale < 1) {
        content.style.transform = 'scale(' + scale + ')';
        content.style.transformOrigin = 'top center';
      }
    });
  }

  function scaleAll() {
    scaleMathBlocks();
    scaleSlideContent();
  }

  renderMath();

  Reveal.initialize({
    hash: true,
    slideNumber: false,   // we render our own counter between the arrows
    transition: '{{ meta.transition.value }}',
    plugins: [ RevealNotes ],
  });

  // Run after Reveal finishes layout and on every navigation / resize
  Reveal.on('ready', scaleAll);
  Reveal.on('slidechanged', scaleAll);
  Reveal.on('resize', scaleAll);

  // ---- Custom slide counter positioned between ← and → arrows ----
  var slCounter = document.getElementById('sl-counter');

  function updateCounter() {
    if (!slCounter) return;
    var idx = Reveal.getIndices();
    var total = Reveal.getTotalSlides();
    slCounter.textContent = (idx.h + 1) + ' / ' + total;
    positionCounter();
  }

  function positionCounter() {
    if (!slCounter) return;
    var leftBtn  = document.querySelector('.reveal .controls .navigate-left');
    var rightBtn = document.querySelector('.reveal .controls .navigate-right');
    if (!leftBtn || !rightBtn) return;

    var lr = leftBtn.getBoundingClientRect();
    var rr = rightBtn.getBoundingClientRect();

    // Centre the counter horizontally between the two arrows,
    // and vertically align with their mid-point.
    var cx = (lr.right + rr.left) / 2;
    var cy = (lr.top  + lr.bottom) / 2;

    slCounter.style.left = (cx - slCounter.offsetWidth  / 2) + 'px';
    slCounter.style.top  = (cy - slCounter.offsetHeight / 2) + 'px';
  }

  Reveal.on('ready',        updateCounter);
  Reveal.on('slidechanged', updateCounter);
  Reveal.on('resize',       positionCounter);

  // External navigation via postMessage (used by the editor sidebar)
  window.addEventListener('message', function(e) {
    if (e.data && e.data.type === 'sl-navigate' && typeof e.data.index === 'number') {
      Reveal.slide(e.data.index);
    }
  });

  // End-of-deck indicator
  var endBanner = document.getElementById('sl-end-banner');
  function updateEndBanner() {
    if (!endBanner) return;
    var isLast = !Reveal.hasNextSlide();
    endBanner.style.opacity = isLast ? '1' : '0';
    endBanner.style.pointerEvents = isLast ? 'auto' : 'none';
  }
  Reveal.on('ready', updateEndBanner);
  Reveal.on('slidechanged', updateEndBanner);

  document.querySelectorAll('.sl-image img').forEach(function(img) {
    img.onerror = function() { this.style.display = 'none'; };
  });

  document.querySelectorAll('canvas[data-chart-config]').forEach(function(canvas) {
    try {
      var cfg = JSON.parse(canvas.dataset.chartConfig);
      new Chart(canvas, cfg);
    } catch (e) { console.error('chart init failed', e); }
  });
</script>
</body>
</html>
